<% if recommendation.pending? %>
  <!-- 選択前の表示（pending） -->
  <div class="d-grid gap-2 d-md-flex justify-content-md-center mt-4">
    <%= form_with url: favorite_recommendation_path(recommendation),
                  method: :patch do |f| %>
      <%= f.button type: :submit, class: "btn btn-primary btn-lg" do %>
        <i class="bi bi-heart-fill"></i> お気に入り
      <% end %>
    <% end %>
    <%= form_with url: skip_recommendation_path(recommendation),
                  method: :patch do |f| %>
      <%= f.button type: :submit, class: "btn btn-outline-secondary btn-sm" do %>
        <i class="bi bi-skip-forward"></i> スキップ
      <% end %>
    <% end %>
  </div>
<% elsif recommendation.favorited? %>
  <!-- お気に入り済みの表示 -->
  <div class="text-center mt-4">
    <div class="alert alert-success mb-3">
      <i class="bi bi-heart-fill"></i> <strong>この推しをお気に入りに追加しました!</strong>
    </div>

    <div class="mb-4 p-3 bg-light rounded">
      <p class="mb-2 text-muted">
        <i class="bi bi-megaphone-fill"></i> この出会いをシェアしませんか？
      </p>
      <%= link_to recommendation_twitter_share_url(recommendation), 
          target: "_blank", 
          rel: "noopener noreferrer",
          class: "btn btn-info btn-lg mb-3" do %>
        <i class="bi bi-twitter"></i> 推しツケられたことをシェアする
      <% end %>
    </div>

    <div class="d-grid gap-2 d-md-flex justify-content-md-center">
      <%= link_to post_path(post), class: "btn btn-primary" do %>
        <i class="bi bi-arrow-right"></i> 投稿詳細を見る
      <% end %>
      <%= link_to recommendations_user_path(recommendation.user), class: "btn btn-outline-info" do %>
        <i class="bi bi-clock-history"></i> 推し発見履歴を見る
      <% end %>
    </div>
  </div>
<% elsif recommendation.skipped? %>
  <!-- スキップ済みの表示 -->
  <div class="text-center mt-4">
    <div class="alert alert-secondary mb-3">
      <i class="bi bi-skip-forward"></i> <strong>スキップしました</strong>
    </div>
    <div class="d-grid gap-2 d-md-flex justify-content-md-center">
      <%= link_to post_path(post), class: "btn btn-primary" do %>
        <i class="bi bi-arrow-right"></i> 投稿詳細を見る
      <% end %>
      <%= link_to recommendations_user_path(recommendation.user), class: "btn btn-outline-info" do %>
        <i class="bi bi-clock-history"></i> 推し発見履歴を見る
      <% end %>
    </div>
  </div>
<% end %>
